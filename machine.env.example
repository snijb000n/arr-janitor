# Machine-specifieke instellingen voor de anime-scripts (anime_sort/anime_audio).
# Kopieer naar machine.env (of laat ./setup.sh dit genereren) — machine.env
# staat in .gitignore. Zonder machine.env gelden de defaults in anime_common.py
# (= de waarden van TheBeastServer).

# Fleet-brede secrets-file (RADARR_API_KEY, SONARR_API_KEY, EMBY_API_KEY,
# TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID, ...)
SECRETS_FILE=/home/sven/scripts/secrets/config.env

# Logdirectory (RotatingFileHandler; wordt aangemaakt indien afwezig)
LOG_DIR=/home/sven/scripts/logs

# Basis van de host-mediamappen. Verwachte submappen:
#   movies, NL-movies, Anime-movies, tv, NL-tv, Anime-tv
MEDIA_ROOT=/home/sven/media

# Machinenaam in Telegram-berichten (default: hostname)
#HOST_LABEL=TheBeastServer

# dv-guard vervang-motor (defaults in dv_guard.py):
#DV_ACTIVE_NIGHTS=7     # nachten normale search voor een item geparkeerd wordt
#DV_REPLACE_WEEKDAY=6   # motor-dag (Python weekday: 0=ma ... 6=zo)
#DV_REPLACE_CAP=15      # max vervang-pogingen per motor-run
#DV_REPLACE_ENABLE=true # motor uitzetten kan met false

# Alleen nodig als een submapnaam afwijkt van de standaard hierboven:
#MOVIES_DIR=/home/sven/media/movies
#NL_MOVIES_DIR=/home/sven/media/NL-movies
#ANIME_MOVIES_DIR=/home/sven/media/Anime-movies
#TV_DIR=/home/sven/media/tv
#NL_TV_DIR=/home/sven/media/NL-tv
#ANIME_TV_DIR=/home/sven/media/Anime-tv
