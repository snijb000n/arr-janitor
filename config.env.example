# arr-janitor configuration TEMPLATE.
# Kopieer naar config.env en vul de secrets in:  cp config.env.example config.env && chmod 600 config.env
# config.env zelf staat in .gitignore en hoort NIET in git.

# *arr instances
RADARR_URL=http://localhost:7878
RADARR_API_KEY=
SONARR_URL=http://localhost:8989
SONARR_API_KEY=

# Host-paden (wat dit script ziet op de host)
RADARR_DOWNLOADS_HOST=/path/to/downloads/completed/Movies
SONARR_DOWNLOADS_HOST=/path/to/downloads/completed/tv

# Container-paden (wat de *arr API in `folder=` query verwacht)
RADARR_DOWNLOADS_CONTAINER=/downloads/completed/Movies
SONARR_DOWNLOADS_CONTAINER=/downloads/completed/tv

# Veiligheidsdrempels
MIN_FILE_AGE_MIN=15
STALLED_HOURS=2
MAX_REMOVE_PER_RUN=200
MAX_IMPORT_PER_RUN=50
RESEARCH_AFTER_BLOCKLIST=true

# Fuzzy-match fallback: voor 'Unknown Series/Movie' rejections proberen we
# de file te koppelen aan een bestaande Sonarr/Radarr entry op basis van
# titel-gelijkenis. Drempel 0..1 — hoger = strenger, lager = ruimer.
FUZZY_MATCH_ENABLED=true
FUZZY_MATCH_THRESHOLD=0.75

# IMPORT_MODE: Copy = origineel blijft staan (veilig, rollbackbaar).
# Switch naar Move na ~2 weken stabiele werking.
IMPORT_MODE=Copy

# Verwijder queue-rows waarvan de file al in de library zit (gebeurt na een
# succesvolle ManualImport via fuzzy-match — Sonarr/Radarr ruimt de
# oorspronkelijke grab-history row niet automatisch op). Geen blocklist,
# geen removeFromClient (download is al schoon).
ZOMBIE_CLEANUP_ENABLED=true
MAX_ZOMBIE_REMOVE_PER_RUN=100

# --- anime reclassify (subcommando `anime`, eigen nachtelijke cron) ---
# Detecteert welke Sonarr-series anime zijn en zet ze op seriesType=anime,
# de anime-root en het anime-profiel. Verplaatst de files mee (moveFiles).
#
# Detectiebron:
#   both = TMDb (anime-keyword of Animation+JP) OF TheTVDB-genre 'Anime'  (aanbevolen)
#   tvdb = alleen Sonarr's eigen 'Anime'-genre (geen API-key nodig)
#   tmdb = alleen TMDb-lookup
ANIME_DETECTION=both
# Gratis TMDb v3 API-key: themoviedb.org -> Settings -> API. Leeg = TVDB-only.
TMDB_API_KEY=
# Doel-rootfolder (container-pad zoals Sonarr het kent) en quality profile.
# Profielnaam wordt los van spaties/streepjes/case gematcht.
ANIME_ROOT_FOLDER=/anime-tv
ANIME_QUALITY_PROFILE=Ultra-HD - Anime
# Files fysiek meeverhuizen naar de anime-root (Sonarr moveFiles).
ANIME_MOVE_FILES=true
# RefreshSeries na elke wijziging (anime absolute-numbering re-parse).
ANIME_REFRESH_AFTER=true
# Cap per run — eerste run kan tientallen series raken; verhoog desnoods.
MAX_ANIME_RECLASSIFY_PER_RUN=25
# Sonarr series-id's die NOOIT verplaatst mogen worden (komma-gescheiden).
# Vul hier false positives in die je in --dry-run ziet.
ANIME_EXCLUDE_IDS=

# --- plex audio language (subcommando `plexlang`, eigen nachtelijke cron) ---
# Zet in Plex per aflevering de default audiotrack op de ORIGINELE taal, maar
# UITSLUITEND voor anime: een Plex-show wordt alleen aangeraakt als hij op
# tvdbId/tmdbId matcht met een Sonarr-serie die seriesType=anime heeft.
# Ondertitels worden NIET aangeraakt (regelt het aparte subtitle-script).
PLEX_URL=http://localhost:32400
# X-Plex-Token. Pak hem uit een 'View XML'-URL in de Plex-webapp (een item ->
# ... -> Get Info -> View XML; de URL bevat X-Plex-Token=...).
PLEX_TOKEN=
# Beperk tot Plex-secties op naam (komma-gescheiden). Leeg = alle show-secties;
# er worden sowieso alleen anime-shows aangeraakt (Sonarr-match op id).
PLEX_ANIME_SECTIONS=
# Fallback audio-voorkeur (ISO-639-2, in volgorde) als TMDb geen
# original_language geeft. Japans -> Koreaans -> Chinees.
PLEX_AUDIO_FALLBACK=jpn,kor,zho
# Cap aantal gewijzigde delen per run. Eerste backfill kan hoog zijn; daarna
# is het idempotent en blijft het laag.
MAX_PLEX_AUDIO_PARTS_PER_RUN=1000
